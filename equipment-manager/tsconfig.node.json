{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "electron-vite/node"]
  },
  "include": ["electron/**/*", "electron.vite.config.ts", "drizzle.config.ts", "vitest.config.ts"]
}
